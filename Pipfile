[[source]]
name = "pypi"
url = "https://pypi.org/simple"
verify_ssl = true

[dev-packages]

[packages]
flask-migrate = "==4.0.5"
flask-swagger = "==0.2.14"
psycopg2-binary = "*"
python-dotenv = "==1.0.0"
# mysqlclient = "==2.2.0"
pymysql = "*"
flask-cors = "==4.0.0"
gunicorn = "*"
flask-admin = "==1.6.1"
wtforms = "==3.0.1"
eralchemy2 = "*"
flask-sqlalchemy = "*"
sqlalchemy = "*"
flask = "*"

[requires]
python_version = "3.13"

[scripts]
start="python -m flask --app src/app run -p 3000 -h 0.0.0.0"
init="python -m flask --app src/app db init"
migrate="python -m flask --app src/app db migrate"
reset_db="bash ./docs/assets/reset_migrations.bash"
upgrade="python -m flask --app src/app db upgrade"
diagram = "eralchemy2 -i 'postgresql://gitpod:postgres@localhost:5432/example' -o diagram.png"
deploy="echo 'Please follow this 3 steps to deploy: https://start.4geeksacademy.com/deploy/render' "
